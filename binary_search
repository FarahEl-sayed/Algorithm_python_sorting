def binarySearch(arr, targted_value):
  low = 0
  high = len(arr) - 1

  while low <= high:
    mid = (low + high) // 2

    if arr[mid] == targted_value:
      return mid

    if arr[mid] < targted_value:
      low = mid + 1
    else:
      high = mid - 1

  return -1

my_list=[0,1,2,4,5,6,7,9]
result=binarySearch(my_list, 4)

if result != -1:
  print("Found at index", result)
else:
  print("Not found")